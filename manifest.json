{
  "name": "YouTube Seek Buttons",
  "version": "0.1.0",
  "description": "Adds fast forward and rewind buttons to YouTube's video player",
  "permissions": ["storage"],
  "host_permissions": ["https://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/watch*"],
      "js": ["contentScript.js"],
      "css": ["ext-styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/rewind.svg",
        "assets/fast-forward.svg"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "YouTube Seek Buttons",
    "default_popup": "popup.html"
  },
  "manifest_version": 3
}