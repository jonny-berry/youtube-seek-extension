{
  "name": "YouTube Seek Buttons",
  "version": "0.1.0",
  "description": "Adds fast forward and rewind buttons to YouTube's video player",
  "permissions": ["storage"],
  "host_permissions": ["https://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["contentScript.js"]
    }
  ],
  "action": {
    "default_title": "YouTube Seek Buttons",
    "default_popup": "popup.html"
  },
  "manifest_version": 3
}